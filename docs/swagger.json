{
  "openapi": "3.0.3",
  "info": {
    "title": "ChatServerGolang — Messenger API",
    "description": "Полноценный сервер мессенджера на Go.\n\n**Функции:**\n- Регистрация и авторизация (JWT с refresh)\n- Личные и групповые чаты\n- Отправка, редактирование, удаление, поиск сообщений\n- Ответы (reply) и пересылка (forward) сообщений\n- Реакции на сообщения (emoji)\n- Закреплённые сообщения (pin)\n- Статус прочтения (read receipts)\n- Загрузка файлов и изображений\n- Голосовые/видеозвонки (WebRTC signaling)\n- Push-уведомления (FCM)\n- WebSocket real-time (онлайн статус, печатание, события)\n- Статус пользователя (WhatsApp-like)\n- Блокировка пользователей\n- Настройки уведомлений на чат (mute)\n- Rate limiting\n- Смена пароля\n- Удаление аккаунта",
    "version": "2.0.0"
  },
  "servers": [
    { "url": "http://localhost:8080", "description": "Локальный сервер" }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["username", "email", "password", "displayName"],
        "properties": {
          "username": { "type": "string", "minLength": 3, "maxLength": 32, "example": "john_doe" },
          "email": { "type": "string", "format": "email", "example": "john@example.com" },
          "password": { "type": "string", "format": "password", "minLength": 6, "example": "secret123" },
          "displayName": { "type": "string", "minLength": 1, "maxLength": 64, "example": "John Doe" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "token": { "type": "string" },
              "user": { "$ref": "#/components/schemas/User" }
            }
          }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "displayName": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "bio": { "type": "string" },
          "status": { "type": "string", "description": "Статус пользователя (Available, Busy, At work, ...)" },
          "online": { "type": "boolean" },
          "lastSeen": { "type": "string", "format": "date-time" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "username": { "type": "string" },
          "displayName": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "bio": { "type": "string" },
          "status": { "type": "string" },
          "online": { "type": "boolean" },
          "lastSeen": { "type": "string", "format": "date-time" }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "avatarUrl": { "type": "string" },
          "type": { "type": "string", "enum": ["private", "group"] },
          "createdBy": { "type": "string" },
          "participants": { "type": "array", "items": { "$ref": "#/components/schemas/UserResponse" } },
          "lastMessage": { "$ref": "#/components/schemas/MessageResponse" },
          "unreadCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "CreateChatRequest": {
        "type": "object",
        "required": ["type", "participantIds"],
        "properties": {
          "name": { "type": "string", "maxLength": 64, "description": "Название группового чата" },
          "description": { "type": "string", "maxLength": 512 },
          "type": { "type": "string", "enum": ["private", "group"] },
          "participantIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "chatId": { "type": "string" },
          "sender": { "$ref": "#/components/schemas/UserResponse" },
          "content": { "type": "string" },
          "type": { "type": "string", "enum": ["text", "image", "file", "system"] },
          "replyTo": { "$ref": "#/components/schemas/MessageResponse" },
          "forwardFrom": { "$ref": "#/components/schemas/UserResponse" },
          "fileName": { "type": "string" },
          "fileSize": { "type": "integer" },
          "fileUrl": { "type": "string" },
          "reactions": { "type": "array", "items": { "$ref": "#/components/schemas/Reaction" } },
          "pinned": { "type": "boolean" },
          "readBy": { "type": "array", "items": { "$ref": "#/components/schemas/UserResponse" } },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "edited": { "type": "boolean" },
          "deleted": { "type": "boolean" }
        }
      },
      "SendMessageRequest": {
        "type": "object",
        "required": ["content", "type"],
        "properties": {
          "content": { "type": "string", "description": "Текст сообщения" },
          "type": { "type": "string", "enum": ["text", "image", "file"] },
          "replyToId": { "type": "string", "description": "ID сообщения для ответа" },
          "forwardMsgId": { "type": "string", "description": "ID сообщения для пересылки" }
        }
      },
      "Reaction": {
        "type": "object",
        "properties": {
          "messageId": { "type": "string" },
          "userId": { "type": "string" },
          "emoji": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "user": { "$ref": "#/components/schemas/UserResponse" }
        }
      },
      "Call": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "chatId": { "type": "string" },
          "callerId": { "type": "string" },
          "calleeId": { "type": "string" },
          "status": { "type": "string", "enum": ["initiated", "ongoing", "ended", "missed", "rejected"] },
          "startedAt": { "type": "string", "format": "date-time" },
          "endedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "error": { "type": "string" }
        }
      }
    }
  },
  "security": [{ "BearerAuth": [] }],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Регистрация нового пользователя",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } } }
        },
        "responses": {
          "201": { "description": "Успешная регистрация" },
          "400": { "description": "Ошибка валидации" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Вход в систему",
        "security": [],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } } }
        },
        "responses": {
          "200": { "description": "Успешный вход" },
          "401": { "description": "Неверные данные" }
        }
      }
    },
    "/api/auth/refresh": {
      "get": {
        "tags": ["Auth"],
        "summary": "Обновить JWT токен",
        "description": "Создаёт новый JWT токен для текущего пользователя без повторного входа",
        "responses": { "200": { "description": "Новый токен" } }
      }
    },
    "/api/auth/change-password": {
      "put": {
        "tags": ["Auth"],
        "summary": "Сменить пароль",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["oldPassword", "newPassword"],
                "properties": {
                  "oldPassword": { "type": "string", "format": "password" },
                  "newPassword": { "type": "string", "format": "password", "minLength": 6 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Пароль изменён" }, "400": { "description": "Ошибка" } }
      }
    },
    "/api/users/profile": {
      "get": {
        "tags": ["Users"],
        "summary": "Профиль текущего пользователя",
        "responses": { "200": { "description": "Профиль пользователя" } }
      },
      "put": {
        "tags": ["Users"],
        "summary": "Обновить профиль",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "displayName": { "type": "string", "maxLength": 64 },
                  "bio": { "type": "string", "maxLength": 256 },
                  "avatarUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Профиль обновлён" } }
      }
    },
    "/api/users/status": {
      "put": {
        "tags": ["Users"],
        "summary": "Обновить статус (как в WhatsApp)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": { "type": "string", "example": "Available", "description": "Новый статус (Available, Busy, At work, Sleeping, ...)" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Статус обновлён" } }
      }
    },
    "/api/users/push-token": {
      "put": {
        "tags": ["Users"],
        "summary": "Обновить push-токен",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token", "provider"],
                "properties": {
                  "token": { "type": "string" },
                  "provider": { "type": "string", "enum": ["fcm", "apns"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Push-токен обновлён" } }
      }
    },
    "/api/users/push-test": {
      "post": {
        "tags": ["Users"],
        "summary": "Отправить тестовое push-уведомление",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["title", "body"],
                "properties": {
                  "title": { "type": "string" },
                  "body": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Тестовый push отправлен" } }
      }
    },
    "/api/users/search": {
      "get": {
        "tags": ["Users"],
        "summary": "Поиск пользователей",
        "parameters": [
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Поисковый запрос" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "Список пользователей" } }
      }
    },
    "/api/users/{id}": {
      "get": {
        "tags": ["Users"],
        "summary": "Пользователь по ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Пользователь найден" }, "404": { "description": "Не найден" } }
      }
    },
    "/api/users/username/{username}": {
      "get": {
        "tags": ["Users"],
        "summary": "Пользователь по username",
        "parameters": [
          { "name": "username", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Пользователь найден" }, "404": { "description": "Не найден" } }
      }
    },
    "/api/users/block": {
      "post": {
        "tags": ["Users"],
        "summary": "Заблокировать пользователя",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["blockedId"],
                "properties": { "blockedId": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Пользователь заблокирован" } }
      }
    },
    "/api/users/block/{userId}": {
      "delete": {
        "tags": ["Users"],
        "summary": "Разблокировать пользователя",
        "parameters": [
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Пользователь разблокирован" } }
      }
    },
    "/api/users/blocked": {
      "get": {
        "tags": ["Users"],
        "summary": "Список заблокированных пользователей",
        "responses": { "200": { "description": "Список заблокированных" } }
      }
    },
    "/api/users/account": {
      "delete": {
        "tags": ["Users"],
        "summary": "Удалить аккаунт (soft delete)",
        "responses": { "200": { "description": "Аккаунт удалён" } }
      }
    },
    "/api/chats": {
      "get": {
        "tags": ["Chats"],
        "summary": "Список чатов текущего пользователя",
        "responses": { "200": { "description": "Список чатов" } }
      },
      "post": {
        "tags": ["Chats"],
        "summary": "Создать чат (личный или групповой)",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateChatRequest" } } }
        },
        "responses": { "201": { "description": "Чат создан" } }
      }
    },
    "/api/chats/{id}": {
      "get": {
        "tags": ["Chats"],
        "summary": "Детали чата",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Информация о чате" }, "404": { "description": "Чат не найден" } }
      },
      "put": {
        "tags": ["Chats"],
        "summary": "Обновить группу (имя, описание, аватар)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "maxLength": 64 },
                  "description": { "type": "string", "maxLength": 256 },
                  "avatarUrl": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Группа обновлена" } }
      },
      "delete": {
        "tags": ["Chats"],
        "summary": "Удалить чат (только создатель)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Чат удалён" } }
      }
    },
    "/api/chats/{id}/participants": {
      "post": {
        "tags": ["Chats"],
        "summary": "Добавить участника в группу",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["userId"],
                "properties": { "userId": { "type": "string" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Участник добавлен" } }
      }
    },
    "/api/chats/{id}/participants/{userId}": {
      "delete": {
        "tags": ["Chats"],
        "summary": "Удалить участника из группы",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Участник удалён" } }
      }
    },
    "/api/chats/{id}/participants/{userId}/role": {
      "put": {
        "tags": ["Chats"],
        "summary": "Назначить роль (admin/member)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": { "type": "string", "enum": ["admin", "member"] }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Роль обновлена" } }
      }
    },
    "/api/chats/{id}/leave": {
      "post": {
        "tags": ["Chats"],
        "summary": "Покинуть групповой чат",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Вы вышли из чата" } }
      }
    },
    "/api/chats/{id}/read": {
      "post": {
        "tags": ["Chats"],
        "summary": "Отметить чат прочитанным",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Помечено" } }
      }
    },
    "/api/chats/{id}/notifications": {
      "put": {
        "tags": ["Chats"],
        "summary": "Включить/выключить уведомления (mute)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["muted"],
                "properties": { "muted": { "type": "boolean", "description": "true — отключить уведомления" } }
              }
            }
          }
        },
        "responses": { "200": { "description": "Настройки обновлены" } }
      },
      "get": {
        "tags": ["Chats"],
        "summary": "Проверить статус уведомлений",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Статус уведомлений" } }
      }
    },
    "/api/chats/{id}/messages": {
      "get": {
        "tags": ["Messages"],
        "summary": "Получить сообщения чата",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "Сообщения" } }
      },
      "post": {
        "tags": ["Messages"],
        "summary": "Отправить сообщение",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/SendMessageRequest" } } }
        },
        "responses": { "201": { "description": "Сообщение отправлено" } }
      }
    },
    "/api/chats/{id}/messages/search": {
      "get": {
        "tags": ["Messages"],
        "summary": "Поиск по сообщениям в чате",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "q", "in": "query", "required": true, "schema": { "type": "string" }, "description": "Поисковый запрос" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 50 } },
          { "name": "offset", "in": "query", "schema": { "type": "integer", "default": 0 } }
        ],
        "responses": { "200": { "description": "Результаты поиска" } }
      }
    },
    "/api/chats/{id}/messages/file": {
      "post": {
        "tags": ["Messages"],
        "summary": "Загрузить файл/изображение",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file"],
                "properties": {
                  "file": { "type": "string", "format": "binary" },
                  "replyToId": { "type": "string", "description": "ID сообщения для ответа" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Файл загружен" } }
      }
    },
    "/api/chats/{id}/messages/{msgId}/resend": {
      "post": {
        "tags": ["Messages"],
        "summary": "Переслать сообщение (resend)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "msgId", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "201": { "description": "Сообщение переслано" } }
      }
    },
